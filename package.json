{
  "name": "voidflag",
  "version": "1.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "description": "Type-safe feature flags and remote config SDK for Node.js — schema-first, real-time, zero runtime overhead.",
  "license": "MIT",
  "keywords": [
    "feature-flags",
    "feature-toggles",
    "remote-config",
    "sdk",
    "typescript",
    "sse",
    "real-time",
    "rollout",
    "schema-first",
    "voidflag"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --emitDeclarationOnly && node build.mjs",
    "test": "vitest --watch --reporter verbose --logHeapUsage"
  },
  "dependencies": {
    "@types/node": "^25.2.3",
    "esbuild": "^0.27.4",
    "eventsource": "^4.1.0"
  },
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "@voidflag/shared": "workspace:*",
    "vitest": "^4.0.18"
  }
}
